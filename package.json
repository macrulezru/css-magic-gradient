{
  "name": "css-magic-gradient",
  "version": "1.2.9",
  "description": "Generate CSS linear, radial and conic gradients with presets, color harmony and WCAG contrast utilities. Vanilla JS / Vue 3 / React.",
  "author": "macrulez <macrulezru@gmail.com> (https://macrulez.ru/en)",
  "license": "MIT",
  "homepage": "https://github.com/macrulezru/css-magic-gradient#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/macrulezru/css-magic-gradient.git"
  },
  "bugs": {
    "url": "https://github.com/macrulezru/css-magic-gradient/issues"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./vue": {
      "types": "./dist/vue-gradient-plugin.d.ts",
      "import": "./dist/vue-gradient-plugin.js",
      "require": "./dist/vue-gradient-plugin.js"
    },
    "./react": {
      "types": "./dist/react-gradient-plugin.d.ts",
      "import": "./dist/react-gradient-plugin.js",
      "require": "./dist/react-gradient-plugin.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "prepublishOnly": "npm run build",
    "build": "tsc"
  },
  "keywords": [
    "css",
    "gradient",
    "linear-gradient",
    "radial-gradient",
    "conic-gradient",
    "color",
    "wcag",
    "vue",
    "vue3",
    "react",
    "typescript"
  ],
  "peerDependencies": {
    "react": ">=17.0.0",
    "vue": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "vue": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  },
  "dependencies": {
    "color-value-tools": "^1.1.6"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/vue": "^1.0.31",
    "@vue/reactivity": "^3.5.27",
    "@vue/runtime-core": "^3.5.27",
    "typescript": "^5.0.0",
    "vue": "^3.5.27"
  }
}
